generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Product {
  id          String   @id @default(uuid())
  name        String
  description String?
  price       Float
  priceM      Float?
  priceG      Float?
  imageUrl    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  batches       Batch[]
  notifications AvailabilityNotification[]
}

model Batch {
  id              String   @id @default(uuid())
  productId       String
  product         Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  
  availableDate   DateTime // Data/Hora em que a fornada ficará (ou ficou) disponível
  totalCapacity   Int      // Capacidade total do forno para essa fornada
  soldQuantity    Int      @default(0) // Quantos já foram vendidos / encomendados
  
  isImmediateSale Boolean  @default(false) // Indica se é uma venda imediata (queima de estoque)
  observation     String?  // Campo de observação facultativo
  
  orderItems      OrderItem[]
  cartReservations CartReservation[]
  notifications   AvailabilityNotification[]

  createdAt       DateTime @default(now())
}

model CartReservation {
  id        String   @id @default(uuid())
  batchId   String
  batch     Batch    @relation(fields: [batchId], references: [id], onDelete: Cascade)
  quantity  Int
  sessionId String   // Para identificar o carrinho do usuário
  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([batchId])
  @@index([sessionId])
  @@unique([sessionId, batchId])
}

model Order {
  id            String   @id @default(uuid())
  customerName  String
  customerPhone String
  
  deliveryType  String   // "RETIRADA" | "ENTREGA"
  address       String?  // Rua, número, bairro
  zipCode       String?  // CEP
  freightCost   Float    @default(0.0)

  totalAmount   Float
  status        String   @default("PENDING") // PENDING, PAID, PREPARING, SHIPPED, COMPLETED

  createdAt     DateTime @default(now())
  items         OrderItem[]
}

model OrderItem {
  id        String   @id @default(uuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  
  batchId   String
  batch     Batch    @relation(fields: [batchId], references: [id], onDelete: Cascade)
  
  quantity  Int
  pricePaid Float    // Snapshot do preço pago no momento

  createdAt DateTime @default(now())
}

model Gallery {
  id        String   @id @default(uuid())
  imageUrl  String
  createdAt DateTime @default(now())
}

model AvailabilityNotification {
  id            String   @id @default(uuid())
  productId     String
  product       Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  customerName  String
  customerPhone String
  notified      Boolean  @default(false)
  batchId       String?  // Opcional: link para a fornada que disparou o aviso
  batch         Batch?   @relation(fields: [batchId], references: [id], onDelete: SetNull)
  createdAt     DateTime @default(now())
}
