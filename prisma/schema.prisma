generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Product {
  id          String   @id @default(uuid())
  name        String
  description String?
  price       Float
  imageUrl    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  batches     Batch[]
}

model Batch {
  id              String   @id @default(uuid())
  productId       String
  product         Product  @relation(fields: [productId], references: [id])
  
  availableDate   DateTime // Data/Hora em que a fornada ficará (ou ficou) disponível
  totalCapacity   Int      // Capacidade total do forno para essa fornada
  soldQuantity    Int      @default(0) // Quantos já foram vendidos / encomendados
  isImmediateSale Boolean  @default(false) // Define se é "Pronta Entrega"
  
  orderItems      OrderItem[]

  createdAt       DateTime @default(now())
}

model Order {
  id            String   @id @default(uuid())
  customerName  String
  customerPhone String
  
  deliveryType  String   // "RETIRADA" | "ENTREGA"
  address       String?  // Rua, número, bairro
  zipCode       String?  // CEP
  freightCost   Float    @default(0.0)

  totalAmount   Float
  status        String   @default("PENDING") // PENDING, PAID, PREPARING, SHIPPED, COMPLETED

  createdAt     DateTime @default(now())
  items         OrderItem[]
}

model OrderItem {
  id        String   @id @default(uuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id])
  
  batchId   String
  batch     Batch    @relation(fields: [batchId], references: [id])
  
  quantity  Int
  pricePaid Float    // Snapshot do preço pago no momento

  createdAt DateTime @default(now())
}
